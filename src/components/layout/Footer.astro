---
const footerLinks = [
  {
    label: "Product",
    links: [
      { label: "Digital Book", href: "/digital-book" },
      { label: "Physical Book", href: "/physical-book" },
      { label: "Pricing", href: "/pricing" },
      { label: "FAQ", href: "/faq" },
      { label: "Comparisons", href: "/comparison" },
    ],
  },
  {
    label: "Comparisons",
    links: [
      { label: "Photobox", href: "/compare/photobox" },
      { label: "Vistaprint", href: "/compare/vistaprint" },
      { label: "Gelato", href: "/compare/gelato" },
      { label: "Canvas", href: "/compare/canvas" },
      { label: "Cookidoo", href: "/compare/cookidoo" },
      { label: "Blurb", href: "/compare/blurb" },
      { label: "Manual", href: "/compare/manuellement" },
    ],
  },
  {
    label: "Legal",
    links: [
      { label: "Privacy policy", href: "/privacy-policy" },
      { label: "Terms of use", href: "/cgu" },
    ],
  },
];

const year = new Date().getFullYear();
const footerDescription =
  "Save, organize, and print your recipes in an elegant cookbook.";
---

<footer class="border-t border-border py-16 px-6 md:px-12 bg-surface">
  <div
    class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-12"
  >
    <!-- Logo & Description -->
    <div class="md:w-1/4 space-y-4">
      <div class="flex items-center gap-2 font-bold text-lg">
        <div
          class="w-8 h-8 text-brand-muted bg-brand rounded-lg flex items-center justify-center"
        >
          <!-- SVG logo -->
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
            ></path>
          </svg>
        </div>
        <span>Kulinia.</span>
      </div>

      <p class="text-text-muted text-sm">
        {footerDescription}
      </p>
    </div>

    <!-- Links -->
    <div
      class="grid grid-cols-2 sm:grid-cols-3 gap-8 md:w-3/4 md:justify-items-end"
    >
      {
        footerLinks.map((col: any) => (
          <div class="space-y-4">
            <h3 class="font-bold text-text-primary text-sm uppercase tracking-wider">
              {col.label}
            </h3>

            <ul class="space-y-3 text-sm text-text-muted">
              {col.links.map((link: any) => (
                <li>
                  <a
                    href={link.href}
                    class="hover:text-brand transition-colors whitespace-nowrap"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bottom bar -->
  <div
    class="max-w-7xl mx-auto mt-16 pt-8 border-t border-border/50 flex items-center justify-center text-sm text-text-faint"
  >
    <p>© {year} Kulinia.</p>
  </div>
</footer>
