---
import "../../styles/global.css";
import { Image } from "astro:assets";
import Shape from "../../assets/hp/shape.svg";

import featureImageCreate from "../../assets/hp/features/create.png";
import featureImageScan from "../../assets/hp/features/scan.png";
import featureImageDashboard from "../../assets/hp/features/dashboard.png";
import featureImageDetails from "../../assets/hp/features/details.png";
import featureImageOrder from "../../assets/hp/features/order.png";
import featureImagePdfViewer from "../../assets/hp/features/pdf-viewer.png";

const { content } = Astro.props;

const STEPS_DATA = [
  {
    tag: content[0].tag,
    title: content[0].title,
    imageLeft: false,
    shapePosition: "-top-20 -right-56",
    features: [
      { title: "Dashboard", desc: content[0].features[0].desc, image: featureImageDashboard },
      { title: "Create", desc: content[0].features[1].desc, image: featureImageCreate },
      { title: "Scan", desc: content[0].features[2].desc, image: featureImageScan },
    ],
    activeIndex: 1,
  },
  {
    tag: content[1].tag,
    title: content[1].title,
    imageLeft: true,
    shapePosition: "-left-56 -bottom-20",
    features: [
      { title: "PDF Viewer", desc: content[1].features[0].desc, image: featureImagePdfViewer },
      { title: "Details", desc: content[1].features[1].desc, image: featureImageDetails },
      { title: "Order", desc: content[1].features[2].desc, image: featureImageOrder },
    ],
    activeIndex: 0,
  },
];
---

<section id="how-it-works" class="py-24 px-6 md:px-12 bg-brand-light overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col gap-32">
    {STEPS_DATA.map((step, stepIdx) => (
      <div class="flex flex-col gap-10 step-container" data-step={stepIdx}>
        <div class="lg:w-1/2 flex flex-col gap-4">
          <span class="px-4 py-1.5 w-fit text-brand bg-brand-muted rounded-pill text-sm font-bold uppercase tracking-wider">
            {step.tag}
          </span>
          <h2 class="text-4xl md:text-5xl font-black tracking-tight">
            {step.title}
          </h2>
        </div>

        {/* ── Layout mobile / tablet ─────────────────────────── */}
        <div class="lg:hidden flex flex-col gap-12">
          {step.features.map((feature) => (
            <div class="bg-surface rounded-card p-6 flex flex-col gap-6 shadow-sm">
              <div>
                <h3 class="text-xl font-bold">{feature.title}</h3>
                <p class="text-gray-600 mt-2">{feature.desc}</p>
              </div>
              <div class="w-full aspect-4/3 bg-gray-200 rounded-xl overflow-hidden">
                <Image
                  src={feature.image}
                  alt={feature.title}
                  class="object-cover w-full h-full"
                  width={800}
                  height={600}
                />
              </div>
            </div>
          ))}
        </div>

        {/* ── Layout desktop ──────────────────────────────────── */}
        <div class="hidden lg:flex w-full items-center gap-0">
          {/* Bloc Texte */}
          <div
            class:list={[
              "space-y-8 bg-surface w-full rounded-3xl lg:w-2/5 p-10 z-10",
              step.imageLeft
                ? "lg:order-2 lg:rounded-tl-none lg:rounded-bl-none"
                : "lg:order-1 lg:rounded-tr-none lg:rounded-br-none",
            ]}
          >
            {step.features.map((feature, fIdx) => (
              <div
                class:list={[
                  "feature-trigger flex gap-4 cursor-pointer transition-all",
                  { "items-start opacity-60 hover:opacity-100": fIdx !== step.activeIndex }
                ]}
                data-index={fIdx}
                data-image={feature.image.src}
              >
                <div>
                  <h3 class="text-xl font-bold">{feature.title}</h3>
                  <p class="text-gray-600 mt-1">
                    {feature.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>

          {/* Bloc Image */}
          <div class:list={["lg:w-1/2 w-full", step.imageLeft ? "lg:order-1" : "lg:order-2"]}>
            <div class="relative w-full aspect-square md:aspect-4/3">
              <div class:list={["size-125 z-0 w-full mx-auto absolute", step.shapePosition]}>
                <Image
                  src={Shape}
                  alt="Shape background"
                  class="w-full h-full"
                  width={300}
                  height={300}
                />
              </div>
              
              <div class="relative z-10 w-full h-full bg-gray-200 rounded-[2rem] flex items-center justify-center shadow-xl overflow-hidden">
                <div class="w-full h-full transition-opacity duration-300 main-img-wrapper">
                  <Image
                    id={`main-img-${stepIdx}`}
                    src={step.features[step.activeIndex].image}
                    alt="Feature preview"
                    class="object-cover w-full h-full"
                    width={1000}
                    height={1000}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const containers = document.querySelectorAll('.step-container');

  containers.forEach(container => {
    const triggers = container.querySelectorAll('.feature-trigger');
    const mainImg = container.querySelector('img[id^="main-img-"]') as HTMLImageElement;
    const imgWrapper = container.querySelector('.main-img-wrapper');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const newSrc = trigger.getAttribute('data-image');
        
        if (mainImg && newSrc && mainImg.src !== newSrc) {
          // Animation simple de switch
          if (imgWrapper) {
            imgWrapper.classList.add('opacity-0');
            setTimeout(() => {
              mainImg.src = newSrc;
              imgWrapper.classList.remove('opacity-0');
            }, 150);
          } else {
            mainImg.src = newSrc;
          }
        }

        // Mise à jour des classes actives sur les textes
        triggers.forEach(t => {
          t.classList.add('items-start', 'opacity-60', 'hover:opacity-100');
        });
        trigger.classList.remove('items-start', 'opacity-60', 'hover:opacity-100');
      });
    });
  });
</script>