---
import Layout from "../layouts/Layout.astro";

const locale = "en";

const sections = [
  {
    title: "1. Data collected",
    content:
      "We collect your email, imported recipes, preferences, and usage data to improve the service.",
  },
  {
    title: "2. Purposes",
    content:
      "Your data is used to manage your account, personalize your experience, and provide relevant services.",
  },
  {
    title: "3. Retention",
    content:
      "Your data is kept while your account is active and deleted within 30 days after closure unless law requires longer.",
  },
  {
    title: "4. Your rights",
    content:
      "You can request access, correction, deletion, or portability of your data at contact@kulinia.com.",
  },
];
---

<Layout
  title="Privacy Policy | Kulinia"
  description="Learn how we collect, use, and protect your data."
  url="https://www.kulinia.com/privacy-policy"
  locale={locale}
>
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 md:px-8">
    <nav class="flex items-center mb-6">
      <a
        href="/"
        class="text-sm font-medium text-text-secondary hover:text-brand transition flex items-center gap-1.5"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to homepage
      </a>
    </nav>
    <div class="mb-12">
      <span class="text-sm font-bold uppercase tracking-wider text-brand">
        Learn how we collect, use, and protect your data.
      </span>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mt-3 mb-4">
        Privacy Policy
      </h1>
    </div>

    <div class="space-y-10">
      {
        sections.map((section) => (
          <section>
            <h2 class="text-xl font-bold mb-3">{section.title}</h2>
            <p class="text-text-muted leading-relaxed whitespace-pre-line">
              {section.content}
            </p>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
