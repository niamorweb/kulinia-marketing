---
import dataFromJson from "../../assets/data/lang/compare/fr.json";
import Layout from "../../layouts/Layout.astro";
import Template from "../../components/compare-pages/Template.astro";

const currentComparisonData = dataFromJson.competitors.blurb
---

<Layout
  title={currentComparisonData.meta_title}
  description={currentComparisonData.meta_desc}
  image="/og-image-compare.jpg"
  url="https://www.moncarnetderecettes.fr/compare"
>
  <Fragment slot="head">
    <meta name="keywords" content="comparatif carnet de recettes, Kulinae vs autres, avantages Kulinae" />
  </Fragment>     

  <Template contentData={currentComparisonData} />
  </Layout>