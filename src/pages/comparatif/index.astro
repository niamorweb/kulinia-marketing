---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

const competitors = [
  "gelato",
  "canvas",
  "photobox",
  "vistaprint",
  "blurb",
  "cookidoo",
  "manuellement",
];

const competitorData = {
  gelato: {
    name: "Gelato",
    highlight: "Impression globale",
    pros: ["Bonne qualité d'impression", "Distribution internationale"],
    cons: ["Pas spécialisé recettes", "Aucune structuration culinaire"],
  },
  canvas: {
    name: "Canvas",
    highlight: "Design générique",
    pros: ["Facile à utiliser", "Templates variés"],
    cons: ["Pas pensé pour la cuisine", "Organisation limitée"],
  },
  photobox: {
    name: "Photobox",
    highlight: "Album photo",
    pros: ["Interface simple", "Bonne qualité photo"],
    cons: ["Pas adapté aux recettes", "Pas de structuration"],
  },
  vistaprint: {
    name: "Vistaprint",
    highlight: "Print marketing",
    pros: ["Impression fiable", "Rapide"],
    cons: ["Pas dédié aux livres de recettes", "Peu personnalisable"],
  },
  blurb: {
    name: "Blurb",
    highlight: "Auto-édition",
    pros: ["Très personnalisable", "Qualité pro"],
    cons: ["Complexe", "Long à créer"],
  },
  cookidoo: {
    name: "Cookidoo",
    highlight: "Recettes digitales",
    pros: ["Recettes intégrées", "Guidé"],
    cons: ["Pas personnalisable", "Pas imprimable"],
  },
  manuellement: {
    name: "Manuellement",
    highlight: "DIY",
    pros: ["100% personnel", "Créatif"],
    cons: ["Très long", "Peu esthétique", "Pas imprimé proprement"],
  },
};

const advantages = [
  "Pensé uniquement pour les recettes",
  "Import de photos ultra simple",
  "Organisation automatique",
  "Livre physique premium",
];
---

<Layout
  title="Comparatif | MonCarnetDeRecettes vs alternatives"
  description="Comparez MonCarnetDeRecettes avec les autres solutions pour créer votre livre de recettes personnalisé."
>
<div class="min-h-screen font-sans text-text-primary bg-surface">
  <main>

    {/* --- HERO --- */}
    <header class="px-6 py-20 md:px-12 md:py-32 bg-brand">
      <div class="max-w-5xl mx-auto text-center space-y-8">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight text-white">
          Le meilleur choix pour votre livre de recettes
        </h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Toutes les solutions ne se valent pas. Voici pourquoi notre approche
          est pensée spécialement pour la cuisine.
        </p>
      </div>
    </header>

 {/* --- AVANTAGES PREMIUM --- */}
<section class="py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto space-y-16">

    {/* intro */}
    <div class="max-w-3xl space-y-4">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight">
        Tout est pensé pour vos recettes
      </h2>
      <p class="text-lg text-text-secondary">
        Contrairement aux outils génériques, chaque fonctionnalité est conçue
        pour simplifier la création de votre livre de recettes personnalisé.
      </p>
    </div>

    {/* grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">

      <div class="bg-white p-8 rounded-3xl border border-border shadow-sm hover:shadow-xl transition space-y-4">
        <h3 class="text-xl font-black">
          Importez vos recettes en photo
        </h3>
        <p class="text-text-secondary">
          Prenez simplement une photo de vos recettes papier. L’IA extrait
          automatiquement les ingrédients et les étapes.
        </p>
      </div>

      <div class="bg-white p-8 rounded-3xl border border-border shadow-sm hover:shadow-xl transition space-y-4">
        <h3 class="text-xl font-black">
          Organisation automatique
        </h3>
        <p class="text-text-secondary">
          Vos recettes sont structurées automatiquement pour un rendu clair,
          lisible et agréable à consulter.
        </p>
      </div>

      <div class="bg-white p-8 rounded-3xl border border-border shadow-sm hover:shadow-xl transition space-y-4">
        <h3 class="text-xl font-black">
          Mise en page professionnelle
        </h3>
        <p class="text-text-secondary">
          Chaque page est optimisée pour l’impression, avec une mise en page
          élégante digne d’un vrai livre de cuisine.
        </p>
      </div>

      <div class="bg-white p-8 rounded-3xl border border-border shadow-sm hover:shadow-xl transition space-y-4">
        <h3 class="text-xl font-black">
          Personnalisation en quelques clics
        </h3>
        <p class="text-text-secondary">
          Choisissez vos styles, ajustez votre contenu et créez un livre qui
          vous ressemble vraiment.
        </p>
      </div>

      <div class="bg-white p-8 rounded-3xl border border-border shadow-sm hover:shadow-xl transition space-y-4">
        <h3 class="text-xl font-black">
          Impression & livraison
        </h3>
        <p class="text-text-secondary">
          Recevez votre livre de recettes directement chez vous, imprimé avec
          une qualité premium.
        </p>
      </div>

      <div class="bg-brand text-white p-8 rounded-3xl shadow-xl space-y-4 flex flex-col justify-between">
        <div>
          <h3 class="text-xl font-black">
            Une solution unique
          </h3>
          <p class="opacity-90">
            Contrairement aux autres outils, Kulinia est conçu uniquement pour
            les carnets de recettes.
          </p>
        </div>

        <a href="/signup" class="font-bold underline">
          Créer mon livre →
        </a>
      </div>

    </div>
    </div>
</section>

    {/* --- COMPARATIF CARDS --- */}
    <section class="py-24 px-6 md:px-12 bg-surface-subtle w-full">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-16 space-y-4">
          <h2 class="text-4xl md:text-5xl font-black">
            Comparaison avec les alternatives
          </h2>
          <p class="text-text-secondary text-lg">
            Chaque solution a ses limites — voici les différences clés.
          </p>
        </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
  {competitors.map((key) => {

    // @ts-ignore
    const c = competitorData[key];
    return (
      <a
        href={`/comparatif/${key}`}
        class="group block bg-white rounded-3xl p-8 shadow-sm border border-border hover:shadow-lg transition hover:-translate-y-1"
      >

        <div class="space-y-6">

          <div class="space-y-2">
            <h3 class="text-2xl font-black group-hover:text-brand transition">
              {c.name}
            </h3>
            <p class="text-sm text-text-muted font-medium">
              {c.highlight}
            </p>
          </div>

          <div class="pt-4 border-t border-border flex items-center justify-between">
            <span class="text-sm font-bold text-brand">
              Voir la comparaison
            </span>

            <svg
              class="w-5 h-5 text-brand transform group-hover:translate-x-1 transition"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </div>

        </div>

      </a>
    );
  })}
</div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">

    {/* --- IMAGE GAUCHE --- */}
    <div class="lg:w-1/2">
      <Image
        width={1000}
        height={600}
        src="/src/assets/hp/features/create.png"
        alt="Application Kulinia pour créer un livre de recettes personnalisé"
        class="rounded-3xl shadow-2xl object-cover w-full h-full"
        loading="lazy"
      />
    </div>

    {/* --- TEXTE DROITE --- */}
    <div class="lg:w-1/2 space-y-6">

      <h2 class="text-4xl md:text-5xl font-black leading-tight">
        Pourquoi choisir Kulinia pour créer votre livre de recettes ?
      </h2>

      <p class="text-lg text-text-secondary leading-relaxed">
        Kulinia est une application pensée exclusivement pour les passionnés de cuisine
        qui souhaitent <strong>créer un livre de recettes personnalisé</strong> facilement.
        Contrairement aux outils génériques, tout est conçu pour transformer vos recettes
        en un <strong>livre structuré, élégant et prêt à imprimer</strong>.
      </p>

      <p class="text-lg text-text-secondary leading-relaxed">
        Importez vos recettes en photo, laissez l’intelligence artificielle extraire
        automatiquement les ingrédients et les étapes, puis organisez votre contenu
        en quelques clics. Vous obtenez un <strong>livre de recettes unique</strong>,
        fidèle à votre cuisine et prêt à être partagé ou offert.
      </p>

      <ul class="space-y-3 pt-2">
        <li class="flex items-center gap-3 font-semibold">
          <span class="text-green-600">✓</span>
          Application dédiée aux carnets de recettes
        </li>
        <li class="flex items-center gap-3 font-semibold">
          <span class="text-green-600">✓</span>
          Scan intelligent de recettes papier (OCR + IA)
        </li>
        <li class="flex items-center gap-3 font-semibold">
          <span class="text-green-600">✓</span>
          Mise en page automatique pour impression
        </li>
        <li class="flex items-center gap-3 font-semibold">
          <span class="text-green-600">✓</span>
          Livre physique premium livré chez vous
        </li>
      </ul>

      <div class="pt-6">
        <a
          href="/signup"
          class="px-8 py-4 bg-brand text-white rounded-pill font-bold hover:scale-105 transition shadow-xl inline-block"
        >
          Créer mon livre de recettes
        </a>
      </div>

    </div>

  </div>
</section>

  </main>
</div>
</Layout>