---
import Layout from "../layouts/Layout.astro";

const locale = "en";

const options = [
  {
    badge: "Recommended",
    title: "Premium Physical Book",
    desc: "The complete experience. We print your book on high-quality paper with a hardback cover and deliver it to your home.",
    price: "32 €",
    details: "A5 book, 48 pages, matte finish. Shipping included.",
    cta: "Order my book",
  },
  {
    title: "HD PDF Export",
    desc: "The solution for those in a hurry or who wish to print locally. A high-definition file ready for the printer.",
    price: "9 €",
    details: "PDF file with bleeds and crop marks included.",
    cta: "Get the PDF",
  },
];

const trustItems = [
  "100% secure payment via Stripe",
  "Tracked delivery in 5 to 7 business days",
  "Responsive customer support based in France",
];
---

<Layout
  title="Pricing | Personalized recipe book"
  description="Start your digital book for free. Only pay when you want to immortalize your recipes on paper or export them."
  url="https://www.kulinia.com/pricing"
  locale={locale}
>
  <div class="min-h-screen bg-surface text-text-primary font-sans">
    <section class="py-24 px-6 md:px-12 bg-white text-center">
      <div class="max-w-4xl mx-auto space-y-6">
        <h1 class="text-5xl md:text-6xl font-black tracking-tight">
          One simple price, for a lifetime of memories.
        </h1>
        <p class="text-text-secondary text-lg">
          Start your digital book for free. Only pay when you want to immortalize
          your recipes on paper or export them.
        </p>
      </div>
    </section>

    <section class="py-24 px-4 md:px-12 bg-brand-light">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
        {
          options.map((option, index) => (
            <div
              class={`bg-surface border rounded-panel p-6 lg:p-10 flex flex-col items-center text-center transition ${
                index === 0
                  ? "border-2 border-brand shadow-xl relative"
                  : "border-border shadow-sm hover:border-gray-300"
              }`}
            >
              {index === 0 && (
                <span class="absolute -top-4 bg-brand text-white px-6 py-2 rounded-pill font-bold text-sm shadow-md">
                  {option.badge}
                </span>
              )}

              <h3
                class={`text-2xl font-black mb-4 ${index === 0 ? "mt-2" : ""}`}
              >
                {option.title}
              </h3>

              <p class="text-text-muted mb-8 grow">{option.desc}</p>

              <div class="text-5xl font-black mb-2">{option.price}</div>

              <p class="text-sm text-text-faint font-medium mb-6">
                {option.details}
              </p>

              <a
                href="/signup"
                class={`font-bold px-8 py-3 rounded-pill transition ${
                  index === 0
                    ? "bg-brand text-white hover:bg-brand-hover shadow-lg shadow-rose-900/20"
                    : "text-text-secondary border border-gray-300 hover:bg-surface-subtle-hover"
                }`}
              >
                {option.cta}
              </a>
            </div>
          ))
        }
      </div>
    </section>

    <section class="py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center space-y-8">
        <ul class="space-y-4 text-text-secondary">
          {trustItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  </div>
</Layout>
