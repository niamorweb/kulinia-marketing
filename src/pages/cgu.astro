---
import Layout from "../layouts/Layout.astro";

const locale = "en";

const sections = [
  {
    title: "1. Purpose",
    content:
      "Kulinia provides a platform to create, organize, and print recipe books. These terms define user rights and obligations.",
  },
  {
    title: "2. User account",
    content:
      "You must provide accurate information and protect your login details. Report unauthorized use immediately.",
  },
  {
    title: "3. Intellectual property",
    content:
      "Kulinia's content is protected. Your recipes remain yours, but you grant us the right to host and display them.",
  },
  {
    title: "4. Liability",
    content:
      "Kulinia strives to deliver a stable service. In case of interruption, our liability is limited to amounts paid in the last 12 months.",
  },
];
---

<Layout
  title="Terms of Use | Kulinia"
  description="The rules that govern the use of Kulinia."
  url="https://www.kulinia.com/cgu"
  locale={locale}
>
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 md:px-8">
    <nav class="flex items-center mb-6">
      <a
        href="/"
        class="text-sm font-medium text-text-secondary hover:text-brand transition flex items-center gap-1.5"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to homepage
      </a>
    </nav>
    <div class="mb-12">
      <span class="text-sm font-bold uppercase tracking-wider text-brand">
        The rules that govern the use of Kulinia.
      </span>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mt-3 mb-4">
        Terms of Use
      </h1>
    </div>

    <div class="space-y-10">
      {
        sections.map((section) => (
          <section>
            <h2 class="text-xl font-bold mb-3">{section.title}</h2>
            <p class="text-text-muted leading-relaxed whitespace-pre-line">
              {section.content}
            </p>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
