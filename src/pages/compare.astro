---
import Layout from "../layouts/Layout.astro";

const locale = "en";
const title = "Why Kulinia is the best choice for your recipes";
const description =
  "Compare our cooking-first approach with other general solutions.";
const url = "https://www.kulinia.com/comparison";
const heroTitle = "Why Kulinia is the best choice for your recipes";
const heroDescription =
  "Compare our cooking-first approach with other general solutions.";
const comparisonBasePath = "/compare";
const cardCtaLabel = "View comparison";
const showCardFooter = true;
const seoKeywords =
  "recipe book comparison, cookidoo alternative, photobox alternative, create cookbook online";

const comparisons = [
  {
    slug: "gelato",
    name: "Gelato",
    description:
      "While Gelato is a print-on-demand giant, it lacks the essentials for a cook: software intelligence.",
  },
  {
    slug: "canvas",
    name: "Canvas",
    description:
      "Canvas offers photo books; we create tools for culinary heritage.",
  },
  {
    slug: "photobox",
    name: "Photobox",
    description:
      "Photobox excels at holiday photo albums, but turning your kitchen scribbles into digital text isn't their job. It's ours.",
  },
  {
    slug: "vistaprint",
    name: "Vistaprint",
    description:
      "Vistaprint is a professional marketing tool. For a recipe book, it's a jackhammer when you need a chef's knife.",
  },
  {
    slug: "blurb",
    name: "Blurb",
    description:
      "Blurb targets self-publishers. If you just want a clean, smart, easy-to-fill book, MonCarnet is for you.",
  },
  {
    slug: "mytaste",
    name: "MyTaste",
    description:
      "Storing internet links is fine, owning your own recipes and being able to print them in a prestige book is better.",
  },
  {
    slug: "cookidoo",
    name: "Cookidoo",
    description:
      "Cookidoo imposes its recipes on you. Kulinia lets you showcase your own, your grandmother's, and your friends'.",
  },
  {
    slug: "manuellement",
    name: "Manually (Paper Notebook)",
    description:
      "The charm of paper is undeniable, but the loss of a unique recipe is irreversible. Combine the best of both worlds.",
  },
];

const benefitsTitle = "An experience designed for speed and clarity";
const benefitsItems = [
  {
    title: "Designed for cooking",
    description:
      "A product built to structure your recipes, not just print photos.",
  },
  {
    title: "Photo recipe import",
    description: "Snap your notes or paper recipes and let AI transcribe them.",
  },
  {
    title: "Smart organization",
    description: "Sort recipes by dish, ingredient, or occasion in a few clicks.",
  },
  {
    title: "Premium printed book",
    description: "Receive a stylish cookbook ready to gift and keep.",
  },
];

const processEyebrow = "How it works";
const processTitle = "3 steps from scattered notes to a polished cookbook";
const processSteps = [
  {
    title: "Import",
    description:
      "Add recipes from photos, websites, or manual input in minutes.",
  },
  {
    title: "Structure",
    description:
      "Kulinia formats ingredients, steps, and layout automatically.",
  },
  {
    title: "Share or print",
    description: "Send a link to family or order a premium physical book.",
  },
];

const whyTitle = "Why choose Kulinia?";
const whyItems = [
  {
    title: "Designed for cooking",
    description:
      "Unlike generic tools, everything is designed around your recipes.",
  },
  {
    title: "Built-in AI",
    description: "Scan, OCR, and automatic organization for your recipes.",
  },
  {
    title: "Physical book",
    description: "Turn your digital recipes into a real printed book.",
  },
];

const faqTitle = "Frequently asked questions";
const faqItems = [
  {
    q: "Can I try it before paying?",
    a: "Yes. Your digital cookbook is free to build. You only pay for PDF export or physical printing.",
  },
  {
    q: "Do I keep ownership of my recipes?",
    a: "Yes. Your recipes remain yours at all times. Kulinia helps you organize and publish them.",
  },
  {
    q: "Is it easy for non-technical users?",
    a: "Absolutely. The interface is designed to be simple, guided, and fast to use.",
  },
];

const ctaTitle = "Switch to a true cooking solution";
const ctaDescription = "Try Kulinia for free and feel the difference.";
const ctaButtonLabel = "Create my book";
const ctaButtonHref = "/signup";
---

<Layout title={title} description={description} url={url} locale={locale}>
  <Fragment slot="head">
    <meta name="keywords" content={seoKeywords} />
  </Fragment>
  <div class="min-h-screen bg-surface text-text-primary font-sans">
    <section class="py-24 px-6 md:px-12 bg-white text-center">
      <div class="max-w-4xl mx-auto space-y-8">
        <h1 class="text-5xl md:text-6xl font-black tracking-tight">
          {heroTitle}
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed">
          {heroDescription}
        </p>
      </div>
    </section>

    <section id="comparisons-grid" class="py-24 px-6 md:px-12 bg-brand-light">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            comparisons.map((c) => (
              <a
                href={`${comparisonBasePath}/${c.slug}`}
                class="group bg-white rounded-3xl p-8 shadow-sm border border-border hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
              >
                <div class="space-y-4">
                  <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-black">Kulinia vs {c.name}</h2>
                    <span class="text-brand font-black">vs</span>
                  </div>
                  <p class="text-text-muted leading-relaxed">{c.description}</p>
                </div>
                {
                  showCardFooter && (
                    <div class="pt-6 flex items-center justify-between">
                      <span class="text-sm text-text-secondary">
                        {cardCtaLabel}
                      </span>
                      <svg
                        class="w-5 h-5 text-brand group-hover:translate-x-1 transition"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </div>
                  )
                }
              </a>
            ))
          }
        </div>
      </div>
    </section>

    {
      whyTitle && whyItems.length > 0 && (
        <section class="py-24 px-6 md:px-12 bg-white">
          <div class="max-w-5xl mx-auto text-center space-y-10">
            <h2 class="text-4xl md:text-5xl font-black">{whyTitle}</h2>
            <div class="grid md:grid-cols-3 gap-10 text-left">
              {
                whyItems.map((item) => (
                  <div class="space-y-3">
                    <h3 class="font-bold text-xl">{item.title}</h3>
                    <p class="text-text-muted">{item.description}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </section>
      )
    }

    {
      benefitsTitle && benefitsItems.length > 0 && (
        <section class="py-24 px-6 md:px-12 bg-brand-light">
          <div class="max-w-6xl mx-auto space-y-10">
            <h2 class="text-4xl md:text-5xl font-black text-center tracking-tight">
              {benefitsTitle}
            </h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
              {
                benefitsItems.map((item) => (
                  <article class="bg-surface rounded-panel border border-border p-8 shadow-sm">
                    <h3 class="text-xl font-black mb-3">{item.title}</h3>
                    <p class="text-text-muted leading-relaxed">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>
      )
    }

    {
      processTitle && processSteps.length > 0 && (
        <section class="py-24 px-6 md:px-12 bg-white">
          <div class="max-w-5xl mx-auto space-y-10">
            <div class="text-center space-y-3">
              {
                processEyebrow && (
                  <p class="text-sm uppercase tracking-[0.2em] text-brand font-bold">
                    {processEyebrow}
                  </p>
                )
              }
              <h2 class="text-4xl md:text-5xl font-black tracking-tight">
                {processTitle}
              </h2>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
              {
                processSteps.map((step, index) => (
                  <div class="bg-surface border border-border rounded-panel p-8">
                    <p class="text-brand font-black mb-3">0{index + 1}</p>
                    <h3 class="text-2xl font-black mb-3">{step.title}</h3>
                    <p class="text-text-muted leading-relaxed">
                      {step.description}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </section>
      )
    }

    {
      faqTitle && faqItems.length > 0 && (
        <section class="py-24 px-6 md:px-12 bg-white">
          <div class="max-w-5xl mx-auto space-y-10">
            <h2 class="text-4xl md:text-5xl font-black text-center tracking-tight">
              {faqTitle}
            </h2>
            <div class="space-y-4">
              {
                faqItems.map((item) => (
                  <details class="bg-surface border border-border rounded-panel p-6 group">
                    <summary class="font-bold text-lg cursor-pointer list-none flex justify-between items-center">
                      {item.q}
                      <span class="text-brand group-open:rotate-45 transition">
                        +
                      </span>
                    </summary>
                    <p class="text-text-muted mt-3 leading-relaxed">{item.a}</p>
                  </details>
                ))
              }
            </div>
          </div>
        </section>
      )
    }

    <section class="py-24 px-6">
      <div
        class="max-w-5xl mx-auto bg-brand text-white text-center p-16 rounded-hero relative overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-gradient-to-tr from-rose-600 to-brand"
        >
        </div>
        <div class="relative space-y-6">
          <h2 class="text-4xl md:text-5xl font-black">{ctaTitle}</h2>
          <p class="text-gray-300 text-lg">{ctaDescription}</p>
          <a
            href={ctaButtonHref}
            class="bg-white text-brand px-8 py-4 rounded-pill font-bold inline-block"
          >
            {ctaButtonLabel}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
