---
import dataFromJson from "../../../assets/data/lang/compare/de.json";
import Layout from "../../../layouts/Layout.astro";
import Template from "../../../components/compare-pages/Template.astro";

const contentData = dataFromJson.competitors.lulu;
const locale = "de";
---

<Layout
    title={contentData.meta_title}
    description={contentData.meta_desc}
    image="/og-image-compare.jpg"
    url="https://www.kulinia.com/de/vergleiche/lulu"
    locale={locale}
    ><Template locale={locale} contentData={contentData} /></Layout
>
