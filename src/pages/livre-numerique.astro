---
import { Image } from "astro:assets";
import dataFromJson from "../assets/data/lang/fr.json"; 

import Shape from "../assets/hp/shape.svg";
import DigitalPreviewImg from "../assets/hp/book-sample.jpg";
import Layout from "../layouts/Layout.astro";

const { DigitalBookPage } = dataFromJson;
---

<Layout
  title="Votre cuisine mérite son propre livre | Carnet de recettes numérique personnalisé"
  description="Créez votre carnet de recettes numérique personnalisé. Importez vos recettes en photo, organisez-les et accédez-y depuis n'importe où."
  image="/og-image-digital-book.jpg"
  url="https://www.moncarnetderecettes.fr/livre-numerique"
>
  <Fragment slot="head">
    <!-- Keywords -->
    <meta name="keywords" content="carnet de recettes numérique, livre de cuisine numérique, recettes maison, application carnet de recettes, organiser recettes en ligne" />
  </Fragment>
<div class="min-h-screen font-sans text-text-primary bg-surface">
  <main>
    <header class="relative flex flex-col items-center justify-between px-6 py-20 md:px-12 md:py-32 overflow-hidden">
      <div class="max-w-7xl w-full mx-auto flex flex-col lg:flex-row items-center gap-12">
        <div class="lg:w-1/2 space-y-8 z-10">
          <div class="inline-block px-4 py-1.5 bg-brand-muted text-brand rounded-full text-sm font-bold">
            100% Gratuit
          </div>
          <h1 class="text-5xl md:text-7xl leading-[1.1] font-black tracking-tight text-balance">
            {DigitalBookPage.hero.title}
          </h1>
          <p class="text-lg text-text-secondary max-w-xl leading-relaxed">
            {DigitalBookPage.hero.description}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/signup" class="px-8 py-4 bg-brand text-white rounded-full font-bold hover:bg-brand-hover transition shadow-lg shadow-rose-900/20 text-center">
              {DigitalBookPage.hero.ctaPrimary}
            </a>
            <a href="#features" class="px-8 py-4 bg-surface-subtle border border-border text-text-primary rounded-full font-bold hover:bg-surface-subtle-hover transition text-center">
              {DigitalBookPage.hero.ctaSecondary}
            </a>
          </div>
        </div>

        <div class="lg:w-1/2 relative">
          <div class="absolute inset-0 bg-brand/5 blur-3xl rounded-full"></div>
          <Image
            src={DigitalPreviewImg}
            alt="Interface du carnet numérique"
            width={600}
            height={500}
            loading="eager"
            class="relative z-10 drop-shadow-2xl h-auto w-full rounded-2xl"
          />
        </div>
      </div>
    </header>

    <section id="features" class="py-24 px-6 md:px-12 bg-surface-subtle">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {DigitalBookPage.features.map((item, idx) => (
            <div class="p-8 bg-surface rounded-[2rem] border border-border shadow-sm">
              <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center text-brand mb-6">
                <span class="font-bold text-xl">{idx + 1}</span>
              </div>
              <h3 class="text-xl font-bold mb-3">{item.title}</h3>
              <p class="text-text-muted leading-relaxed text-sm">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-surface">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black text-center mb-16 tracking-tight">
          {DigitalBookPage.comparison.title}
        </h2>
        <div class="overflow-x-auto border border-border rounded-[2rem] shadow-sm">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-surface-subtle">
                <th class="p-6 font-bold border-b border-border">{DigitalBookPage.comparison.table.feature}</th>
                <th class="p-6 font-bold border-b border-border text-brand">{DigitalBookPage.comparison.table.us}</th>
                <th class="p-6 font-bold border-b border-border text-text-faint">{DigitalBookPage.comparison.table.others}</th>
              </tr>
            </thead>
            <tbody>
              <!-- {DigitalBookPage.comparison.rows.map((row) => (
                <tr class="hover:bg-surface-subtle/50 transition">
                  <td class="p-6 border-b border-border font-medium">{row[0]}</td>
                  <td class="p-6 border-b border-border text-brand font-bold">
                    <span class="flex items-center gap-2">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      {row[1]}
                    </span>
                  </td>
                  <td class="p-6 border-b border-border text-text-muted">{row[2]}</td>
                </tr>
              ))} -->
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto relative group">
        <Image
          src={Shape}
          alt=""
          width={160}
          height={160}
          class="absolute -top-12 -left-12 opacity-20 rotate-12 pointer-events-none"
        />
        <div class="bg-brand rounded-[3rem] p-12 md:p-20 text-center text-white shadow-2xl relative overflow-hidden">
          <div class="relative z-10 space-y-8">
            <h2 class="text-4xl md:text-5xl font-black">{DigitalBookPage.cta.title}</h2>
            <p class="text-lg text-rose-100 max-w-xl mx-auto">{DigitalBookPage.cta.description}</p>
            <a href="/signup" class="px-10 py-5 bg-surface text-brand rounded-full font-black hover:scale-105 transition shadow-xl inline-block">
              {DigitalBookPage.cta.button}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
</Layout>