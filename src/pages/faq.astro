---
import Layout from "../layouts/Layout.astro";

const locale = "en";

const categories = {
  general: "General",
  digital: "Digital Book & AI",
  physical: "Printing & Delivery",
};

const items = [
  {
    category: "digital",
    q: "How does text recognition (OCR) work?",
    a: "Simply take a photo of your handwritten or printed recipe. Our AI analyzes the image, identifies ingredients, quantities, and steps, then automatically transcribes them into your book. You can then correct or complete the text if needed.",
  },
  {
    category: "digital",
    q: "Can I import recipes from websites?",
    a: "Yes! Just copy the recipe URL. Our tool extracts the useful content (ingredients and preparation) while removing ads and fluff.",
  },
  {
    category: "general",
    q: "Can I share my book with my family?",
    a: "Absolutely. You can generate a sharing link for a single recipe or your entire book. Your loved ones can view it for free on their phone or computer.",
  },
  {
    category: "physical",
    q: "What are the delivery times for the physical book?",
    a: "Once your order is confirmed, printing usually takes 2 business days. Home delivery then takes between 3 and 5 days depending on your location.",
  },
  {
    category: "physical",
    q: "Can I choose my book's layout?",
    a: "We offer several elegant themes. Once your recipes are selected, our algorithm automatically generates an optimized layout, but you keep control over the cover choice and chapter order.",
  },
  {
    category: "physical",
    q: "What is the 'Bleeds' option in the PDF export?",
    a: "This is a technical safety margin. If you choose to print your PDF professionally, these edges prevent white lines when the paper is cut. Your file is thus 100% compliant with printing standards.",
  },
  {
    category: "general",
    q: "Is my data secure?",
    a: "Your recipes belong to you. We use SSL encryption for all your data and we never resell your personal information.",
  },
];
---

<Layout
  title="FAQ | Kulinia"
  description="Everything you need to know about Kulinia, from digital creation to printing your book."
  url="https://www.kulinia.com/faq"
  locale={locale}
>
  <div class="min-h-screen bg-surface text-text-primary font-sans">
    <section class="py-24 px-6 md:px-12 bg-white text-center">
      <div class="max-w-4xl mx-auto space-y-6">
        <h1 class="text-5xl md:text-6xl font-black tracking-tight">
          Frequently Asked Questions
        </h1>
        <p class="text-text-secondary text-lg">
          Everything you need to know about Kulinia, from digital creation to
          printing your book.
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-brand-light">
      <div class="max-w-4xl mx-auto space-y-16">
        <div>
          <h2 class="text-2xl font-black mb-6">{categories.general}</h2>
          <div class="space-y-4">
            {
              items
                .filter((i) => i.category === "general")
                .map((item) => (
                  <details class="bg-white rounded-2xl p-6 shadow-sm group">
                    <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                      {item.q}
                      <span class="text-brand group-open:rotate-45 transition">
                        +
                      </span>
                    </summary>
                    <p class="text-text-muted mt-4 leading-relaxed">{item.a}</p>
                  </details>
                ))
            }
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-black mb-6">{categories.digital}</h2>
          <div class="space-y-4">
            {
              items
                .filter((i) => i.category === "digital")
                .map((item) => (
                  <details class="bg-white rounded-2xl p-6 shadow-sm group">
                    <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                      {item.q}
                      <span class="text-brand group-open:rotate-45 transition">
                        +
                      </span>
                    </summary>
                    <p class="text-text-muted mt-4 leading-relaxed">{item.a}</p>
                  </details>
                ))
            }
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-black mb-6">{categories.physical}</h2>
          <div class="space-y-4">
            {
              items
                .filter((i) => i.category === "physical")
                .map((item) => (
                  <details class="bg-white rounded-2xl p-6 shadow-sm group">
                    <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                      {item.q}
                      <span class="text-brand group-open:rotate-45 transition">
                        +
                      </span>
                    </summary>
                    <p class="text-text-muted mt-4 leading-relaxed">{item.a}</p>
                  </details>
                ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 bg-white text-center">
      <div class="max-w-3xl mx-auto space-y-6">
        <h2 class="text-3xl md:text-4xl font-black">
          Didn't find the answer to your question?
        </h2>
        <p class="text-text-secondary">
          Our team is here to help you quickly.
        </p>
        <a
          href="mailto:contact@kulinia.com"
          class="inline-block px-10 py-5 bg-brand text-white font-bold rounded-pill hover:bg-brand-hover transition shadow-xl"
        >
          Contact our support
        </a>
      </div>
    </section>
  </div>
</Layout>
