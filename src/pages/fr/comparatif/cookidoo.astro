---
import dataFromJson from "../../../assets/data/lang/compare/fr.json";
import Layout from "../../../layouts/Layout.astro";
import Template from "../../../components/compare-pages/Template.astro";

const currentComparisonData = dataFromJson.competitors.cookidoo;
const locale = "fr";
---

<Layout
  title={currentComparisonData.meta_title}
  description={currentComparisonData.meta_desc}
  image="/og-image-compare.jpg"
  url="https://www.kulinia.com/compare"
 locale={locale}>
  <Fragment slot="head">
    <meta
      name="keywords"
      content="comparatif livre de recettes, Kulinia vs autres, avantages Kulinia"
    />
  </Fragment>

  <Template locale={locale} contentData={currentComparisonData} />
</Layout>
