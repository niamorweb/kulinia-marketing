---
import Layout from "../layouts/Layout.astro";

const { contentData, locale = "fr" } = Astro.props;
---

<Layout
    title="FAQ | Kulinia"
    description={contentData.description}
    url="https://www.kulinia.com/faq"
    locale={locale}
>
    <div class="min-h-screen bg-surface text-text-primary font-sans">
        {/* --- HERO --- */}
        <section class="py-24 px-6 md:px-12 bg-white text-center">
            <div class="max-w-4xl mx-auto space-y-6">
                <h1 class="text-5xl md:text-6xl font-black tracking-tight">
                    {contentData.title}
                </h1>
                <p class="text-text-secondary text-lg">
                    {contentData.description}
                </p>
            </div>
        </section>

        {/* --- FAQ --- */}
        <section class="py-24 px-6 md:px-12 bg-brand-light">
            <div class="max-w-4xl mx-auto space-y-16">
                {/* GENERAL */}
                <div>
                    <h2 class="text-2xl font-black mb-6">
                        {contentData.categories.general}
                    </h2>
                    <div class="space-y-4">
                        {
                            contentData.items
                                .filter((i) => i.category === "general")
                                .map((item) => (
                                    <details class="bg-white rounded-2xl p-6 shadow-sm group">
                                        <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                                            {item.q}
                                            <span class="text-brand group-open:rotate-45 transition">
                                                +
                                            </span>
                                        </summary>
                                        <p class="text-text-muted mt-4 leading-relaxed">
                                            {item.a}
                                        </p>
                                    </details>
                                ))
                        }
                    </div>
                </div>

                {/* DIGITAL */}
                <div>
                    <h2 class="text-2xl font-black mb-6">
                        {contentData.categories.digital}
                    </h2>
                    <div class="space-y-4">
                        {
                            contentData.items
                                .filter((i) => i.category === "digital")
                                .map((item) => (
                                    <details class="bg-white rounded-2xl p-6 shadow-sm group">
                                        <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                                            {item.q}
                                            <span class="text-brand group-open:rotate-45 transition">
                                                +
                                            </span>
                                        </summary>
                                        <p class="text-text-muted mt-4 leading-relaxed">
                                            {item.a}
                                        </p>
                                    </details>
                                ))
                        }
                    </div>
                </div>

                {/* PHYSICAL */}
                <div>
                    <h2 class="text-2xl font-black mb-6">
                        {contentData.categories.physical}
                    </h2>
                    <div class="space-y-4">
                        {
                            contentData.items
                                .filter((i) => i.category === "physical")
                                .map((item) => (
                                    <details class="bg-white rounded-2xl p-6 shadow-sm group">
                                        <summary class="cursor-pointer font-bold text-lg flex justify-between items-center">
                                            {item.q}
                                            <span class="text-brand group-open:rotate-45 transition">
                                                +
                                            </span>
                                        </summary>
                                        <p class="text-text-muted mt-4 leading-relaxed">
                                            {item.a}
                                        </p>
                                    </details>
                                ))
                        }
                    </div>
                </div>
            </div>
        </section>

        {/* --- CONTACT CTA --- */}
        <section class="py-24 px-6 bg-white text-center">
            <div class="max-w-3xl mx-auto space-y-6">
                <h2 class="text-3xl md:text-4xl font-black">
                    {contentData.notFound}
                </h2>
                <p class="text-text-secondary">
                    {contentData.supportDescription}
                </p>
                <a
                    href="/contact"
                    class="inline-block px-10 py-5 bg-brand text-white font-bold rounded-pill hover:bg-brand-hover transition shadow-xl"
                >
                    {contentData.contact}
                </a>
            </div>
        </section>
    </div>
</Layout>
