---
import BookSampleImg from "../assets/hp/book-sample.jpg";
import Steps from "../components/homepage/Steps.astro";
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Faq from "../components/homepage/Faq.astro";
import { Image } from "astro:assets";

const {
  title = "Carnet de recettes personnalisé",
  description = "Créez, organisez et imprimez vos recettes dans un livre élégant.",
  image = "https://www.kulinia.com/og-image.jpg",
  url = "https://www.kulinia.com/",
  locale = "fr",
  contentData = null
} = Astro.props;

---

<Layout 
  title={title}
  description={description}
  image={image}
  url={url}
  >
  <Fragment slot="head">
  <!-- Keywords (optionnel mais ok) -->
  <meta name="keywords" content="livre de recettes, livre de cuisine personnalisé, recettes maison, impression livre, OCR recette" />

  
</Fragment>
<div class="min-h-screen font-sans text-text-primary bg-surface">

  <main>

    <!-- HERO -->
    <header class="flex flex-col lg:flex-row px-6 py-16 md:px-12 xl:py-32 relative overflow-hidden">
      <div class="max-w-7xl w-full mx-auto flex flex-col lg:flex-row lg:items-center gap-16">

        <div class="xl:w-1/2 space-y-6 max-w-[500px] z-10">
          <h1 class="text-5xl md:text-7xl font-black leading-[1.1]">
            {contentData.hero.title}
          </h1>

          <p class="text-text-secondary leading-[1.8]">
            {contentData.hero.description}
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a class="px-8 py-4 bg-brand text-white rounded-pill font-bold shadow-lg" href="/signup">
              {contentData.hero.ctaPrimary} →
            </a>

            <a class="px-8 py-4 font-semibold text-brand hover:bg-surface-subtle-hover rounded-full" href="#how-it-works">
              {contentData.hero.ctaSecondary}
            </a>
          </div>
        </div>

      </div>

      <Image
        src={BookSampleImg}
        width={1000}
        height={900}
        loading="eager"
        fetchpriority="high"
        alt="Exemple livre"
        class="xl:absolute lg:w-1/2 xl:w-auto xl:right-0 xl:top-0 xl:translate-x-1/3 object-cover rounded-xl"
      />
    </header>

    <!-- STEPS (Astro component statique) -->
    <Steps content={contentData.steps} />

    {/* --- PRICING --- */}
        <section id="prix" class="py-24 px-4 md:px-12 bg-brand-light">
          <div class="max-w-5xl mx-auto space-y-16 bg-surface rounded-panel p-12 md:p-24">
            <div class="text-center space-y-4">
              <h2 class="text-4xl md:text-5xl font-black tracking-tight">
                {contentData.pricing.title}
              </h2>
              <p class="text-text-muted text-lg">
                {contentData.pricing.description}
              </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
              {/* On boucle sur les deux options définies dans le JSON */}
              {[0, 1].map((index) => (
                <div
                  class={`bg-surface border rounded-panel p-6 lg:p-10 flex flex-col items-center text-center transition ${
                    index === 0
                      ? "border-2 border-brand shadow-xl relative"
                      : "border-border shadow-sm hover:border-gray-300"
                  }`}
                >
                  {/* Badge "La plus choisie" uniquement pour la première option */}
                  {index === 0 && (
                    <span class="absolute -top-4 bg-brand text-white px-6 py-2 rounded-pill font-bold text-sm shadow-md">
                      {contentData.pricing.options[0].badge}
                    </span>
                  )}

                  <h3
                    class={`text-2xl font-black mb-4 ${index === 0 ? "mt-2" : ""}`}
                  >
                    {contentData.pricing.options[index].title}
                  </h3>

                  <p class="text-text-muted mb-8 grow">
                    {contentData.pricing.options[index].desc}
                  </p>

                  <div class="text-5xl font-black mb-2">
                    {contentData.pricing.options[index].price}
                  </div>

                  <p class="text-sm text-text-faint font-medium mb-6">
                    {contentData.pricing.options[index].details}
                  </p>

                  <a
                    href="/signup"
                    class={`font-bold px-8 py-3 rounded-pill transition ${
                      index === 0
                        ? "bg-brand text-white hover:bg-brand-hover shadow-lg shadow-rose-900/20"
                        : "text-text-secondary border border-gray-300 hover:bg-surface-subtle-hover"
                    }`}
                  >
                    {contentData.pricing.options[index].cta}
                  </a>
                </div>
              ))}
            </div>
          </div>
        </section>

   <Faq contentData={contentData} />

    <!-- CTA -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto bg-brand text-white text-center p-16 rounded-hero relative overflow-hidden">

        <div class="absolute inset-0 bg-gradient-to-tr from-rose-600 to-brand"></div>

        <div class="relative space-y-6">
          <h2 class="text-4xl font-black">{contentData.cta.title}</h2>
          <p>{contentData.cta.description}</p>

          <a href="/signup" class="bg-white text-brand px-8 py-4 rounded-pill font-bold inline-block">
            {contentData.cta.cta}
          </a>
        </div>

      </div>
    </section>

  </main>
</div>
</Layout>
