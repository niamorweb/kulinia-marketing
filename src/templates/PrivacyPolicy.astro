---
import Layout from "../layouts/Layout.astro";

const { contentData, locale = "fr" } = Astro.props;
---

<Layout locale={locale}>
    <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 md:px-8">
        <nav class="flex items-center mb-6">
            <a
                href="/"
                class="text-sm font-medium text-text-secondary hover:text-brand transition flex items-center gap-1.5"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                {contentData.backButton}
            </a>
        </nav>
        <div class="mb-12">
            <span class="text-sm font-bold uppercase tracking-wider text-brand">
                {contentData.hero.subtitle}
            </span>
            <h1
                class="text-4xl md:text-5xl font-black tracking-tight mt-3 mb-4"
            >
                {contentData.hero.title}
            </h1>
            <p class="text-text-muted">
                {contentData.lastUpdate}
            </p>
        </div>

        <div class="space-y-10">
            {
                contentData.sections.map((section) => (
                    <section>
                        <h2 class="text-xl font-bold mb-3">{section.title}</h2>
                        <p class="text-text-muted leading-relaxed whitespace-pre-line">
                            {section.content}
                        </p>
                    </section>
                ))
            }
        </div>
    </main>
</Layout>
