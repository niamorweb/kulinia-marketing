---
import { Image } from "astro:assets";
import Shape from "../assets/hp/shape.svg";
import Layout from "../layouts/Layout.astro";
import BookHeroImg from "../assets/hp/book-sample.jpg";

const specsKeys = ["0", "1", "2", "3"];
const giftPoints = [0, 1, 2];

const { contentData, locale = "fr" } = Astro.props;
const seoByLocale = {
    fr: {
        title: "Votre cuisine mérite son propre livre | Carnet de recettes personnalisé",
        description:
            "Créez votre livre de recettes personnalisé. Importez vos recettes en photo, organisez-les et imprimez un livre élégant livré chez vous.",
        url: "https://www.kulinia.com/fr/livre-physique",
        heroAlt: "Livre de recettes physique MonCarnetDeRecettes",
        giftAlt: "Offrir un livre de recettes"
    },
    en: {
        title: "Your kitchen deserves its own book | Personalized recipe book",
        description:
            "Create your personalized recipe book. Import your recipes from photos, organize them, and print an elegant book delivered to your home.",
        url: "https://www.kulinia.com/en/physical-book",
        heroAlt: "Physical recipe book",
        giftAlt: "Gift a recipe book"
    },
    de: {
        title: "Deine Küche verdient ihr eigenes Buch | Personalisiertes Rezeptbuch",
        description:
            "Erstelle dein personalisiertes Rezeptbuch. Importiere deine Rezepte per Foto, organisiere sie und drucke ein elegantes Buch für dein Zuhause.",
        url: "https://www.kulinia.com/de/physisches-buch",
        heroAlt: "Physisches Rezeptbuch",
        giftAlt: "Ein Rezeptbuch verschenken"
    },
    es: {
        title: "Tu cocina merece su propio libro | Recetario personalizado",
        description:
            "Crea tu recetario personalizado. Importa tus recetas con fotos, organízalas e imprime un libro elegante entregado en tu casa.",
        url: "https://www.kulinia.com/es/libro-fisico",
        heroAlt: "Libro de recetas físico",
        giftAlt: "Regalar un libro de recetas"
    },
    it: {
        title: "La tua cucina merita il suo libro | Ricettario personalizzato",
        description:
            "Crea il tuo ricettario personalizzato. Importa le tue ricette da foto, organizzale e stampa un libro elegante consegnato a casa.",
        url: "https://www.kulinia.com/it/libro-fisico",
        heroAlt: "Ricettario fisico",
        giftAlt: "Regalare un ricettario"
    },
    nl: {
        title: "Je keuken verdient een eigen boek | Gepersonaliseerd receptenboek",
        description:
            "Maak je gepersonaliseerde receptenboek. Importeer recepten via foto's, organiseer ze en print een elegant boek dat thuis wordt geleverd.",
        url: "https://www.kulinia.com/nl/fysiek-boek",
        heroAlt: "Fysiek receptenboek",
        giftAlt: "Een receptenboek cadeau doen"
    }
};
const seoLocaleKey = (locale in seoByLocale ? locale : "fr") as keyof typeof seoByLocale;
const currentSeo = seoByLocale[seoLocaleKey];
---

<Layout
    title={currentSeo.title}
    description={currentSeo.description}
    image="/og-image.jpg"
    url={currentSeo.url}
    locale={locale}
>
    <div class="min-h-screen font-sans text-text-primary bg-surface">
        <main>
            {/* --- HERO SECTION --- */}
            <header
                class="relative px-6 py-20 md:px-12 md:py-32 overflow-hidden bg-white"
            >
                <div
                    class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
                >
                    <div class="lg:w-1/2 space-y-8">
                        <h1
                            class="text-5xl md:text-7xl font-black leading-tight tracking-tight"
                        >
                            {contentData.hero.title}
                        </h1>
                        <p class="text-text-secondary leading-relaxed">
                            {contentData.hero.description}
                        </p>
                        <div class="flex flex-wrap gap-4">
                            <a
                                href="/signup"
                                class="px-10 py-5 bg-brand text-white rounded-pill font-bold hover:bg-brand-hover transition shadow-xl shadow-rose-900/20"
                            >
                                {contentData.hero.ctaPrimary}
                            </a>
                            <a
                                href="#specs"
                                class="px-10 py-5 bg-white border border-border text-text-primary rounded-pill font-bold hover:bg-surface-subtle-hover transition"
                            >
                                {contentData.hero.ctaSecondary}
                            </a>
                        </div>
                    </div>

                    <div class="lg:w-1/2">
                        <Image
                            src={BookHeroImg}
                            alt={currentSeo.heroAlt}
                            width={700}
                            height={500}
                            class="rounded-3xl shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500"
                            loading="eager"
                        />
                    </div>
                </div>
            </header>

            {/* --- SPECS SECTION --- */}
            <section id="specs" class="py-24 px-6 md:px-12 bg-brand-light">
                <div class="max-w-7xl mx-auto">
                    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">
                        {
                            specsKeys.map((key) => (
                                <div class="space-y-4">
                                    <div class="w-14 h-14 bg-brand rounded-2xl flex items-center justify-center text-white shadow-lg shadow-brand/20">
                                        <svg
                                            class="w-7 h-7"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                    </div>
                                    <h3 class="text-xl font-bold">
                                        {/* @ts-ignore */}
                                        {contentData.specs[key].title}
                                    </h3>
                                    <p class="text-text-muted leading-relaxed">
                                        {/* @ts-ignore */}
                                        {contentData.specs[key].description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            {/* --- HOW IT WORKS SECTION --- */}
            <section class="py-24 px-6 md:px-12 bg-brand-light">
                <div class="max-w-7xl mx-auto space-y-16">
                    <div class="text-center space-y-4">
                        <h2
                            class="text-4xl md:text-5xl font-black tracking-tight"
                        >
                            {/* @ts-ignore */}
                            {contentData.howItWorks?.title}
                        </h2>
                        {
                            /* @ts-ignore */
                            contentData.howItWorks?.description && (
                                <p class="text-text-secondary max-w-2xl mx-auto">
                                    {/* @ts-ignore */}
                                    {contentData.howItWorks.description}
                                </p>
                            )
                        }
                    </div>

                    <div class="w-full h-[600px] rounded-2xl bg-neutral-200">
                    </div>
                </div>
            </section>

            {/* --- GIFT SECTION --- */}
            <section class="py-24 px-6 md:px-12 bg-brand-light">
                <div
                    class="max-w-7xl mx-auto flex flex-col lg:flex-row-reverse items-center gap-16"
                >
                    <div class="lg:w-1/2 space-y-8">
                        <h2
                            class="text-4xl md:text-5xl font-black leading-tight"
                        >
                            {contentData.gift.title}
                        </h2>
                        <p class="text-lg text-text-secondary">
                            {contentData.gift.description}
                        </p>
                        <ul class="space-y-4">
                            {
                                giftPoints.map((idx) => (
                                    <li class="flex items-center gap-3 font-bold text-text-primary">
                                        <div class="w-6 h-6 bg-green-100 text-green-600 rounded-full flex items-center justify-center">
                                            <svg
                                                class="w-4 h-4"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke="currentColor"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="3"
                                                    d="M5 13l4 4L19 7"
                                                />
                                            </svg>
                                        </div>
                                        {contentData.gift.points[idx]}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="lg:w-1/2">
                        <Image
                            src={BookHeroImg}
                            alt={currentSeo.giftAlt}
                            width={600}
                            height={600}
                            class="rounded-panel shadow-lg"
                        />
                    </div>
                </div>
            </section>

            {/* --- CTA FINAL --- */}
            <section class="py-24 px-6 bg-brand-light">
                <div
                    class="max-w-5xl mx-auto bg-text-primary rounded-hero p-12 md:p-20 text-center text-white relative overflow-hidden"
                >
                    <Image
                        src={Shape}
                        alt=""
                        class="absolute top-0 right-0 size-64 opacity-10 translate-x-1/4 -translate-y-1/4"
                    />
                    <div class="relative z-10 space-y-8">
                        <h2
                            class="text-4xl md:text-5xl font-black tracking-tight"
                        >
                            {contentData.cta.title}
                        </h2>
                        <p class="text-xl text-gray-300 max-w-2xl mx-auto">
                            {contentData.cta.description}
                        </p>
                        <a
                            href="/signup"
                            class="px-10 py-5 bg-brand text-white rounded-pill font-black hover:scale-105 transition shadow-2xl inline-block"
                        >
                            {contentData.cta.button}
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </div>
</Layout>
